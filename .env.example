NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_rMLiuaUORxB8J5zgWq6eGw_iVNPsHmj

# Client semver targeting for announcements (optional; defaults to package version).
NEXT_PUBLIC_APP_VERSION=0.0.2

# Server-only (never expose to the browser). Used by GET /api/cron/notification-lifecycle.
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=generate-a-long-random-string
#
# Packaged Electron loads this URL (default http://localhost:3000 if unset).
# For local .app testing: run `npm run start` first, OR set ELECTRON_START_URL to your Vercel URL.
# Optional: ELECTRON_DEBUG=1 opens DevTools in packaged builds (launch from Terminal so env applies).
# ELECTRON_START_URL=https://your-deployment.example.com
#
# Edge Function `check-update` (update banner): deploy to the SAME project as NEXT_PUBLIC_SUPABASE_URL.
#   npx supabase login && npx supabase link --project-ref <your-project-ref>
#   npx supabase functions deploy check-update
# (Secrets SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are injected on hosted; for local serve use `supabase status` URLs.)
# Local serve (optional): npx supabase functions serve
#   Then point NEXT_PUBLIC_SUPABASE_URL at local API, e.g. http://127.0.0.1:54321 from `supabase status`.

# Use the project anon (legacy) or publishable key from Supabase → Settings → API for NEXT_PUBLIC_SUPABASE_ANON_KEY.
#
# Migrations (apply before npm run build):
#   npx supabase login
#   npx supabase link --project-ref omfbstdzlwcnhmhcknls
#   npm run db:push
# Or: npx supabase db push --db-url "postgresql://..."  (URI from Database settings; URL-encode password)
# Local: Docker required — npm run db:start && npm run db:reset
#
# Demo users (apply migrations; password for all below: DemoSeed2026!):
#   demo@ultrafinance.local — superadmin (20260103000011 + 20260103000019)
#   customer1@ultrafinance.local — Demo Customer One (20260103000020)
#   customer2@ultrafinance.local — Demo Customer Two
#   customer3@ultrafinance.local — Demo Customer Three
#
# Optional — Supabase Realtime (Dashboard → Database → Publications):
#   Enable `public.user_notifications` and `public.notifications` so tabs receive
#   rows instantly. Electron can use native notifications via IPC; web uses the
#   Notification API when permission is granted.