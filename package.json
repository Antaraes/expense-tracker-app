{
  "name": "ultrafinance",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"next dev -p 3000\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "dev:next": "next dev -p 3000",
    "build": "next build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:desktop": "npm run build && npm run build:electron && electron-builder",
    "electron:pack": "npm run build && npm run build:electron && electron-builder --dir",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:push:local": "supabase db push --local",
    "db:link": "supabase link",
    "theme:sync": "npx shadcn@latest add @tweakcn/modern-minimal --yes --overwrite"
  },
  "build": {
    "appId": "com.ultrafinance.app",
    "productName": "UltraFinance",
    "directories": {
      "output": "release"
    },
    "files": ["dist-electron/**/*", "package.json"],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.finance"
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "publish": {
      "provider": "github"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "supabase": "^2.84.10",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
